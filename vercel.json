{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://your-backend-url.com/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "framework": "vite",
    "buildCommand": "cd client && npm install && npm run build",
    "outputDirectory": "client/dist"
}