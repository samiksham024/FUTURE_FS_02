{
    "version": 2,
    "functions": {
        "server/index.js": {}
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/server/index.js"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/client/index.html"
        }
    ]
}